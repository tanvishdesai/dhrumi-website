---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="dark" style="scroll-behavior: smooth;">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="RVFET.COM - Personal website of Rafat Abbasli." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>RVFET.COM</title>
        
        <!-- Font preloads -->
        <link rel="preload" href="/fonts/Brachial-UltraBold-UltraWide.woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="/fonts/Brachial-UltraBold.woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="/fonts/PPNeueMachina-PlainVariable.woff2" as="font" type="font/woff2" crossorigin>

        <slot name="head" />
	</head>
	<body class="relative flex flex-col bg-background pt-28 w-full min-h-screen text-foreground overflow-x-hidden transition-colors duration-300">
        <canvas id="grid-canvas" class="fixed inset-0 pointer-events-none z-0"></canvas>
        <script>
            import "../scripts/BackgroundGrid.js";
        </script>

        <!-- Theme Initialization -->
        <script is:inline>
            // Immediately invked function to set theme to avoid FOUC
            (() => {
                const getTheme = () => {
                    const stored = localStorage.getItem("appSettings");
                    if (stored) {
                        try {
                            const parsed = JSON.parse(stored);
                            // Assuming settings might implicitly define theme or we default to dark
                            // The reference implementation seems to check 'themeMode' or 'basecoat:theme'
                            // For simplicity, let's check classList or prefers-color-scheme if specific setting absent
                            return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
                        } catch (e) {
                            console.error(e);
                        }
                    }
                    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                };
                
                // Default to dark for this design
                document.documentElement.classList.add('dark');
            })();
        </script>

		<div class="relative flex flex-col flex-1 z-10 w-full max-w-7xl mx-auto px-4">
			<slot />
		</div>
	</body>
</html>
