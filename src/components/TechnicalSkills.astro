<script>
    import gsap from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";
    import Observer from "gsap/Observer";

    gsap.registerPlugin(ScrollTrigger, Observer);  // Use Observer if needed, though Marquee mainly needs ScrollTrigger for visibility/speed adjustment

    const marquees = document.querySelectorAll(".marquee-inner");

    marquees.forEach((marquee: any) => {
        // Clone children to ensure enough width for looping
        const children = Array.from(marquee.children);
        // Clone enough times to fill width + buffer (simple approach: replicate 3x)
        for(let i=0; i<3; i++) {
            children.forEach((child: any) => {
                marquee.appendChild(child.cloneNode(true));
            });
        }

        const speed = Number(marquee.getAttribute("data-speed")) || 30; // duration in seconds
        const direction = marquee.getAttribute("data-direction") || "left";
        const xPercentStart = direction === "left" ? 0 : -50;
        const xPercentEnd = direction === "left" ? -50 : 0;

        gsap.set(marquee, { xPercent: xPercentStart });

        const tween = gsap.to(marquee, {
            xPercent: xPercentEnd,
            repeat: -1,
            duration: speed,
            ease: "none",
            force3D: true
        });

        let currentVelocity = 0;
        let timeScale = 1;
        let isHovered = false;

        // Use ScrollTrigger to detect scroll velocity
        ScrollTrigger.create({
            trigger: document.body,
            start: "top top",
            end: "bottom bottom",
            onUpdate: (self) => {
                currentVelocity = self.getVelocity();
            }
        });

        // Adjust timeScale based on scroll velocity
        gsap.ticker.add(() => {
            currentVelocity *= 0.95; // dampening
            let targetScale = 1 + Math.abs(currentVelocity) / 500;
            
            if (isHovered) targetScale = 0.1;

            timeScale += (targetScale - timeScale) * 0.015; // smooth interpolation works well
            
            if(tween.isActive()) {
                tween.timeScale(timeScale);
            }
        });

        const parent = marquee.parentElement;
        if (parent) {
            const onEnter = () => { isHovered = true; };
            const onLeave = () => { isHovered = false; };
            
            parent.addEventListener("mouseenter", onEnter);
            parent.addEventListener("mouseleave", onLeave);
            parent.addEventListener("touchstart", onEnter, { passive: true });
            parent.addEventListener("touchend", onLeave);
        }
    });
</script>
