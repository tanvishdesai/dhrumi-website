<script is:inline>
    // Header Scroll Logic
    const header = document.getElementById("navigation-header");
    let lastScroll = 0;
    const threshold = 100;

    function handleScroll() {
        if (!header) return;
        const currentScroll = window.scrollY;
        
        if (currentScroll < threshold) {
            header.style.transform = "translateY(0)";
            lastScroll = currentScroll;
            return;
        }

        if (currentScroll > lastScroll) {
            // Scrolling down
            header.style.transform = "translateY(-150%)";
        } else {
            // Scrolling up
            header.style.transform = "translateY(0)";
        }
        lastScroll = currentScroll;
    }

    document.addEventListener("scroll", handleScroll, { passive: true });

    // Logo Animation trigger
    window.triggerLogoAnimation = function(svg) {
        if (!svg) return;
        const animate = svg.querySelector("path animate");
        if (!animate) return;
        animate.beginElement();
    };

    // Theme Toggle
    window.toggleTheme = function() {
        const isDark = document.documentElement.classList.contains("dark");
        if (isDark) {
            document.documentElement.classList.remove("dark");
            localStorage.setItem("appSettings", JSON.stringify({ theme: "light" })); // Mocking settings
        } else {
            document.documentElement.classList.add("dark");
            localStorage.setItem("appSettings", JSON.stringify({ theme: "dark" }));
        }
        // Emit event for BackgroundGrid
        document.dispatchEvent(new CustomEvent("basecoat:theme"));
    };
</script>
