---

<section class="relative w-full py-20 section-enterance visible">
    <div class="mb-10 text-center">
        <h2 class="relative mb-4 w-full text-base xs:text-lg sm:text-2xl text-center uppercase tracking-wide font-heading font-bold">
            <b class="text-primary">C</b>oded for
            <span id="total-hours" class="h-8 inline-flex items-center rounded-md border border-neutral-200 bg-white px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-950 focus:ring-offset-2 dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-50 mx-2 text-base">
                1643 hours & 15 minutes
            </span>
            this year
        </h2>
        <p class="mt-2 text-muted-foreground text-sm">
            I'm a polyglot developer. Here's a breakdown of the top programming
            languages I've used this year.
        </p>
    </div>

    <div class="relative mt-4 overflow-x-auto overflow-y-hidden">
        <!-- Glow Effects -->
        <div class="absolute top-0 left-0 w-1/3 aspect-square bg-green-500/5 dark:bg-white/10 blur-3xl rounded-full -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute top-1/2 left-1/3 w-1/3 aspect-square bg-black/5 dark:bg-white/5 blur-3xl rounded-full -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute -bottom-1/2 right-0 w-1/3 aspect-square bg-red-500/5 blur-3xl rounded-full -translate-x-1/2 -translate-y-1/2"></div>

        <div class="data-table-wrapper w-full overflow-x-auto">
            <table class="w-full text-sm text-left backdrop-blur-2xl bg-white/5 dark:bg-black/5 rounded-lg overflow-hidden">
                <thead class="text-xs uppercase bg-black/5 dark:bg-white/5 text-muted-foreground">
                    <tr>
                        <th style="width: 33.33%" class="px-6 py-3 font-heading tracking-wider">Language</th>
                        <th style="width: 33.33%" class="px-6 py-3 text-center font-heading tracking-wider">Time spent</th>
                        <th style="width: 33.33%" class="px-6 py-3 text-right font-heading tracking-wider">Percentage</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/50">
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #3572A5"></span>
                            Python
                        </td>
                        <td class="px-6 py-4 text-center">911 hrs 10 mins</td>
                        <td class="px-6 py-4 text-right">55.5%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #00ADD8"></span>
                            Go
                        </td>
                        <td class="px-6 py-4 text-center">192 hrs 51 mins</td>
                        <td class="px-6 py-4 text-right">11.7%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #16ce40"></span>
                            Other
                        </td>
                        <td class="px-6 py-4 text-center">107 hrs 13 mins</td>
                        <td class="px-6 py-4 text-right">6.5%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #ff5a03"></span>
                            Astro
                        </td>
                        <td class="px-6 py-4 text-center">104 hrs 35 mins</td>
                        <td class="px-6 py-4 text-right">6.4%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #f1e05a"></span>
                            JavaScript
                        </td>
                        <td class="px-6 py-4 text-center">61 hrs 12 mins</td>
                        <td class="px-6 py-4 text-right">3.7%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #cb171e"></span>
                            YAML
                        </td>
                        <td class="px-6 py-4 text-center">56 hrs 31 mins</td>
                        <td class="px-6 py-4 text-right">3.4%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #083fa1"></span>
                            Markdown
                        </td>
                        <td class="px-6 py-4 text-center">45 hrs 10 mins</td>
                        <td class="px-6 py-4 text-right">2.8%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #292929"></span>
                            JSON
                        </td>
                        <td class="px-6 py-4 text-center">31 hrs 32 mins</td>
                        <td class="px-6 py-4 text-right">1.9%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #e34c26"></span>
                            HTML
                        </td>
                        <td class="px-6 py-4 text-center">20 hrs 15 mins</td>
                        <td class="px-6 py-4 text-right">1.2%</td>
                    </tr>
                    <tr class="bg-background/50 hover:bg-background/80 transition-colors opacity-0 transform translate-y-4">
                        <td class="px-6 py-4 font-medium whitespace-nowrap flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full inline-block" style="background-color: #dc9658"></span>
                            Bash
                        </td>
                        <td class="px-6 py-4 text-center">18 hrs 28 mins</td>
                        <td class="px-6 py-4 text-right">1.1%</td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr class="bg-black/5 dark:bg-white/5">
                        <td colspan="3" class="px-6 py-3 text-center text-xs uppercase tracking-wider text-muted-foreground font-heading">
                            64 languages in total
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";

    const tables = document.querySelectorAll(".data-table-wrapper");

    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const target = entry.target;
                const rows = target.querySelectorAll("tbody tr");
                
                gsap.to(rows, {
                    autoAlpha: 1, // opacity + visibility
                    y: 0,
                    duration: 0.5,
                    stagger: 0.04,
                    ease: "power2.out",
                    overwrite: true
                });
                
                observer.unobserve(target);
            }
        });
    }, { threshold: 0.15 });

    tables.forEach(table => {
        // Set initial state via GSAP to ensure consistency before animation
        const rows = table.querySelectorAll("tbody tr");
        gsap.set(rows, { autoAlpha: 0, y: 15 });
        
        observer.observe(table);
    });
</script>
