---
---

<section class="relative h-[calc(100vh-7rem)] min-h-[600px] flex flex-col md:flex-row gap-4 md:gap-8 lg:gap-12 w-full max-w-7xl mx-auto items-center justify-between overflow-hidden">
    <!-- Text Content -->
    <div class="flex flex-col gap-6 flex-1 z-10 w-full px-4 md:px-0 mt-12 md:mt-0 pointer-events-none">
        <div class="pointer-events-auto flex flex-col gap-6 items-center md:items-start">
            <h1 class="font-heading text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight leading-[0.9] text-center md:text-left text-foreground">
                RAFAT<br>ABBASLI
            </h1>
            
            <div class="flex gap-3 flex-wrap justify-center md:justify-start">
                <div class="px-4 py-1.5 rounded-full border border-black/10 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm text-sm font-medium">
                    Software Engineer
                </div>
                <div class="px-4 py-1.5 rounded-full border border-black/10 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm text-sm font-medium">
                    Full Stack Developer
                </div>
                <div class="px-4 py-1.5 rounded-full border border-black/10 dark:border-white/10 bg-white/50 dark:bg-white/5 backdrop-blur-sm text-sm font-medium">
                    UI/UX Designer
                </div>
            </div>

            <div class="flex gap-4 items-center justify-center md:justify-start mt-4">
                <a href="/resume.pdf" class="group relative px-6 py-3 rounded-lg bg-foreground text-background font-bold text-lg overflow-hidden transition-all hover:scale-105 active:scale-95">
                    <span class="relative z-10">RESUME</span>
                    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                </a>
                <a href="mailto:info@rvfet.com" class="px-6 py-3 rounded-lg border-2 border-foreground text-foreground font-bold text-lg hover:bg-foreground hover:text-background transition-all duration-300">
                    CONTACT
                </a>
            </div>
        </div>
    </div>

    <!-- Globe Container -->
    <div id="globe-container" class="absolute inset-0 md:static md:w-1/2 h-full flex items-center justify-center pointer-events-auto z-0 md:z-auto opacity-50 md:opacity-100 mask-image-gradient">
        <div id="globeVizWrapper" class="w-full h-full flex items-center justify-center opacity-0 blur-xl transition-all duration-1000">
            <canvas id="globeCanvas" class="w-full h-full max-w-[800px] max-h-[800px] cursor-grab active:cursor-grabbing"></canvas>
        </div>
        
        <!-- Loading State / Fallback could go here -->
    </div>

    <!-- Glitch effect filter for hover (from reference) -->
    <svg style="display: none;">
        <defs>
            <filter id="glitch-home-intro">
                <feTurbulence type="fractalNoise" baseFrequency="0.01 0.005" numOctaves="2" result="noise" />
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="5" xChannelSelector="R" yChannelSelector="G" />
            </filter>
        </defs>
    </svg>
</section>

<style>
    .mask-image-gradient {
        /* Fade out the globe on mobile so text is readable */
        @media (max-width: 768px) {
            mask-image: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,1) 50%, rgba(0,0,0,0.2) 100%);
            -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,1) 50%, rgba(0,0,0,0.2) 100%);
        }
    }
</style>

<script>
    import "../scripts/GlobeBundled.js";
</script>
